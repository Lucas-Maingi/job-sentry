# JobSentry production .env — copy to .env on the server and fill in your keys.
# NEVER commit the real .env.

# --- Real job search (free tier: serper.dev, 2,500 searches) ---
JOBSENTRY_SERPER_API_KEY=

# --- LLM for scoring, cover letters, and ATS resumes (free tier: console.groq.com) ---
JOBSENTRY_LLM_API_KEY=
JOBSENTRY_LLM_BASE_URL=https://api.groq.com/openai/v1
JOBSENTRY_LLM_MODEL=llama-3.3-70b-versatile

# --- Autonomous scanner: how often to re-scan every profile, in minutes ---
# 360 = every 6 hours. Set to 0 to disable the background scanner.
JOBSENTRY_AUTO_SCAN_INTERVAL_MINUTES=360

# --- Optional: recruiter-reply tracking via IMAP (Gmail app password) ---
JOBSENTRY_EMAIL_IMAP_SERVER=imap.gmail.com
JOBSENTRY_EMAIL_USERNAME=
JOBSENTRY_EMAIL_PASSWORD=
